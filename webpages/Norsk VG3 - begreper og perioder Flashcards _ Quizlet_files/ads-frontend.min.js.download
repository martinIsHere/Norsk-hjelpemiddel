/*
    this script is part of our ad blocker detection
    we detect if the div it creates is on the page or not
*/

document.addEventListener("DOMContentLoaded", function(event) {
    var e = document.createElement('div');
    e.id = 'SmF2aWVyIHdhcyBoZXJl';
    e.style.visibility = 'hidden';
    e.style.width = '1px';
    e.style.height = '1px';
    document.body.appendChild(e);
});
